# Accept the peer-dep mismatch between `react-leaflet-cluster@4.1.3`
# (peer: @react-leaflet/core@^3) and our `react-leaflet@4.2.1`
# (ships with @react-leaflet/core@2.1.0). The package works fine in
# practice; the version pin in its package.json is overly strict.
#
# Without this, Vercel's `npm install` fails with ERESOLVE because the
# default npm 9+ behaviour is strict (`legacy-peer-deps=false`). Local
# dev/CI installs need the same flag to stay in sync.
#
# Re-evaluate when upgrading react-leaflet to v5: the cluster package
# may catch up and this file can be removed.
legacy-peer-deps=true
